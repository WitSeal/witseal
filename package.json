{
  "name": "@witseal/cli",
  "version": "0.1.3",
  "description": "A witnessed execution runtime for AI agents.",
  "keywords": [
    "witnessed-execution",
    "ai-agent",
    "agentic-trust-infrastructure",
    "evidence-chain",
    "operational-trust",
    "trust-runtime"
  ],
  "homepage": "https://github.com/WitSeal/witseal",
  "bugs": "https://github.com/WitSeal/witseal/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WitSeal/witseal.git"
  },
  "license": "Apache-2.0",
  "author": "WitSeal contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "witseal": "dist/src/cli/index.js",
    "witseal-mcp": "dist/src/adapters/mcp/bin.js",
    "witseal-witness-claude-code": "dist/src/adapters/claude-code/bin.js"
  },
  "exports": {
    "./exec": {
      "types": "./dist/src/cli/exec.d.ts",
      "import": "./dist/src/cli/exec.js"
    },
    "./adapters/opencode": {
      "types": "./dist/src/adapters/opencode/mediate.d.ts",
      "import": "./dist/src/adapters/opencode/mediate.js"
    },
    "./adapters/mcp": {
      "types": "./dist/src/adapters/mcp/mediate.d.ts",
      "import": "./dist/src/adapters/mcp/mediate.js"
    },
    "./adapters/framework": {
      "types": "./dist/src/adapters/framework/mediate.d.ts",
      "import": "./dist/src/adapters/framework/mediate.js"
    },
    "./adapters/claude-code": {
      "types": "./dist/src/adapters/claude-code/witness.d.ts",
      "import": "./dist/src/adapters/claude-code/witness.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "docs/CLAIM_BOUNDARY.md",
    "examples/policy-packs/",
    "schemas/",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src tests schemas",
    "style-check": "node scripts/style-check.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
